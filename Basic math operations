#include <stdio.h>

int main() {
    float num1, num2;
    float sum, diff, prod, div;

    // Prompt user for input
    printf("Enter two numbers: ");
    scanf("%f %f", &num1, &num2);

    // Perform calculations
    sum = num1 + num2;
    diff = num1 - num2;
    prod = num1 * num2;

    // Display results
    printf("Sum: %.2f\n", sum);
    printf("Difference: %.2f\n", diff);
    printf("Product: %.2f\n", prod);

    // Handle division by zero
    if (num2 != 0) {
        div = num1 / num2;
        printf("Division: %.2f\n", div);
    } else {
        printf("Division: Error (Cannot divide by zero)\n");
    }

    return 0;
}
